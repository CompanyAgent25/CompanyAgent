# CompanyAgent — Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL=postgres://companyagent:companyagent@db:5432/companyagent
REDIS_URL=redis://redis:6379

# Rust API
RUST_API_HOST=0.0.0.0
RUST_API_PORT=8080
RUST_LOG=info
PYTHON_SERVICE_URL=http://python-services:8000

# Python Services
PYTHON_API_HOST=0.0.0.0
PYTHON_API_PORT=8000
RUST_API_URL=http://rust-api:8080

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRATION_HOURS=24
BCRYPT_COST=12

# LLM Provider
# Provider examples:
#   anthropic
#   deepseek
#   openai
#   qwen
#   ollama
#   vllm
#   lmstudio
#   openai-compatible
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=replace-with-anthropic-key
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECONDS=60
LLM_ENABLE_TOOLS=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_PYTHON_API_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
