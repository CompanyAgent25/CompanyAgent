FROM rust:1-slim-bookworm AS rust-builder

RUN apt-get update \
    && apt-get install -y pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY backend/rust-api/Cargo.toml ./Cargo.toml
RUN mkdir src && echo "fn main() {}" > src/main.rs
RUN cargo build --release 2>/dev/null || true
RUN rm -rf src

COPY backend/rust-api/src ./src
COPY backend/rust-api/migrations ./migrations
RUN touch src/main.rs && cargo build --release

FROM python:3.12-slim-bookworm

WORKDIR /app

RUN apt-get update \
    && apt-get install -y ca-certificates libssl3 redis-server redis-tools \
    && rm -rf /var/lib/apt/lists/*

COPY backend/python-services/requirements.txt ./python-services/requirements.txt
RUN pip install --no-cache-dir -r ./python-services/requirements.txt

COPY backend/python-services ./python-services
COPY --from=rust-builder /app/target/release/companyagent-api /usr/local/bin/companyagent-api
COPY infra/start-railway-backend.sh /app/start-backend.sh

RUN chmod +x /app/start-backend.sh

ENV PYTHONPATH=/app/python-services
ENV RUST_API_HOST=0.0.0.0
ENV PYTHON_SERVICE_URL=http://127.0.0.1:8000
ENV REDIS_URL=redis://127.0.0.1:6379

EXPOSE 8080

CMD ["/app/start-backend.sh"]
